{
  "name": "resume-analyser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:sync && concurrently -k -c \"cyan,magenta,yellow\" -n \"NEXT,PRISMA,OLLAMA\" \"next dev\" \"npx prisma studio\" \"ollama serve\"",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:with-server": "concurrently -k -s first \"next dev\" \"sleep 5 && jest\"",
    "db:sync": "npx prisma generate && npx prisma db push",
    "ollama:pull": "ollama pull llama3"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "formidable": "^3.5.4",
    "jsdom": "^29.0.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "next": "16.1.6",
    "next-router-mock": "^1.0.5",
    "node-web-api": "^0.1.6",
    "openai": "^6.29.0",
    "pdf-parse": "^2.4.5",
    "prisma": "^7.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "tesseract.js": "^7.0.0",
    "undici": "^7.24.4",
    "web-streams-polyfill": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/formidable": "^3.5.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "node-fetch": "^2.7.0",
    "node-mocks-http": "^1.17.2",
    "playwright": "^1.58.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
