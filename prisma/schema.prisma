generator client {
  provider = "prisma-client-js"
}

// Provider para SQLite (dev local, sem adapter)
// Em produção/Docker, DATABASE_URL com postgresql:// usa @prisma/adapter-pg
datasource db {
  provider = "sqlite"
}

model AnalysisHistory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String
  analysis  String?  // Resultado final da análise
  content   String   // Texto extraído do currículo
  fileName  String
  status    String   @default("pending") // pending, processing, done, error
  error     String?  // Mensagem de erro, se houver
  user      User     @relation(fields: [userId], references: [id])
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  name             String            @default("Usuário")
  subscriptionType SubscriptionType  @default(FREE)
  tokens           Int               @default(1)
  resumeRewriteCredits Int           @default(0)
  lastTokenRefill  DateTime?         // Para controle de renovação mensal do Pro
  analysisHistory  AnalysisHistory[]
  resumes          Resume[]
}

model Resume {
  id        String   @id @default(uuid())
  fileName  String
  content   String
  analysis  String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

enum SubscriptionType {
  FREE
  PRO
  TEAM
}
